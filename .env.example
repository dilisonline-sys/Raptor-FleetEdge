# ── Trading mode: testnet | demo | live ───────────────────
TRADING_MODE=testnet

# ── Testnet (testnet.binance.vision) ──────────────────────
BINANCE_TESTNET_API_KEY=your_testnet_key
BINANCE_TESTNET_API_SECRET=your_testnet_secret

# ── Demo (demo-api.binance.com / demo.binance.com) ────────
# Create keys at: https://demo.binance.com/en/my/settings/api-management
BINANCE_DEMO_API_KEY=your_demo_key
BINANCE_DEMO_API_SECRET=your_demo_secret

# ── Live (api.binance.com) ────────────────────────────────
# WARNING: real funds. Trade permission only, no withdrawal.
BINANCE_LIVE_API_KEY=your_live_key
BINANCE_LIVE_API_SECRET=your_live_secret

# ── Alerts & agents ───────────────────────────────────────
DIPU_ALERT_WEBHOOK=
DIPU_AUTHORIZED_AGENT_TOKENS=
