# ── Active trading mode: testnet | demo | live ────────────
TRADING_MODE=demo

# ── Testnet credentials (testnet.binance.vision) ──────────
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=

# ── Demo credentials (demo-api.binance.com) ───────────────
BINANCE_DEMO_API_KEY=
BINANCE_DEMO_API_SECRET=

# ── Live credentials (api.binance.com) ────────────────────
# WARNING: real funds. Trade + Read only — NO withdrawal permission.
BINANCE_LIVE_API_KEY=
BINANCE_LIVE_API_SECRET=

# ── Claude analyst (optional) ─────────────────────────────
ANTHROPIC_API_KEY=

# ── Alerts & auth ─────────────────────────────────────────
DIPU_ALERT_WEBHOOK=
DIPU_AUTHORIZED_AGENT_TOKENS=

# ── Email notifications (optional) ───────────────────────
# Configure via the manager dashboard at http://localhost:7430
# Or set here and they'll be loaded on first run.
# Gmail: use an App Password (myaccount.google.com/apppasswords) — NOT your login password.
EMAIL_SENDER=
EMAIL_APP_PASSWORD=
